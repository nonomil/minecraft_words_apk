{
  "version": "1.0",
  "description": "SQLite schema for largebase structured scan",
  "tables": {
    "scan_meta": {
      "description": "扫描元数据",
      "columns": {
        "key": "TEXT PRIMARY KEY",
        "value": "TEXT NOT NULL"
      },
      "sample_keys": [
        "scan_date",
        "scan_mode",
        "scan_scope",
        "scan_topic",
        "reference_docs",
        "module_count",
        "function_count",
        "dataflow_count",
        "constraint_count",
        "impact_item_count"
      ]
    },
    "modules": {
      "description": "模块清单",
      "columns": {
        "id": "TEXT PRIMARY KEY",
        "path": "TEXT NOT NULL",
        "name": "TEXT NOT NULL",
        "responsibility": "TEXT",
        "exported_symbols": "TEXT",
        "dependencies": "TEXT",
        "file_count": "INTEGER",
        "loc": "INTEGER"
      }
    },
    "functions": {
      "description": "公共函数/类",
      "columns": {
        "id": "TEXT PRIMARY KEY",
        "module_id": "TEXT NOT NULL",
        "name": "TEXT NOT NULL",
        "signature": "TEXT",
        "file_path": "TEXT",
        "line_number": "INTEGER",
        "called_by": "TEXT",
        "calls": "TEXT",
        "is_public": "BOOLEAN"
      }
    },
    "dataflows": {
      "description": "数据流",
      "columns": {
        "id": "TEXT PRIMARY KEY",
        "name": "TEXT NOT NULL",
        "input_format": "TEXT",
        "output_format": "TEXT",
        "steps": "TEXT",
        "side_effects": "TEXT",
        "related_functions": "TEXT"
      }
    },
    "data_structures": {
      "description": "核心数据结构",
      "columns": {
        "id": "TEXT PRIMARY KEY",
        "name": "TEXT NOT NULL",
        "fields": "TEXT",
        "used_by": "TEXT",
        "storage_layer": "TEXT"
      }
    },
    "constraints": {
      "description": "约束汇总",
      "columns": {
        "id": "TEXT PRIMARY KEY",
        "source_doc": "TEXT",
        "constraint_type": "TEXT",
        "content": "TEXT",
        "impact_scope": "TEXT",
        "priority": "TEXT"
      }
    },
    "impact_items": {
      "description": "影响矩阵",
      "columns": {
        "id": "TEXT PRIMARY KEY",
        "change_point": "TEXT",
        "direct_impact": "TEXT",
        "indirect_impact": "TEXT",
        "verification_points": "TEXT",
        "risk_level": "TEXT"
      }
    },
    "reference_docs": {
      "description": "参考文档",
      "columns": {
        "id": "TEXT PRIMARY KEY",
        "path": "TEXT NOT NULL",
        "purpose": "TEXT",
        "key_sections": "TEXT",
        "conflicts_with": "TEXT"
      }
    }
  },
  "indexes": [
    "CREATE INDEX idx_modules_path ON modules(path)",
    "CREATE INDEX idx_functions_module ON functions(module_id)",
    "CREATE INDEX idx_functions_name ON functions(name)",
    "CREATE INDEX idx_constraints_type ON constraints(constraint_type)",
    "CREATE INDEX idx_impact_risk ON impact_items(risk_level)"
  ]
}
